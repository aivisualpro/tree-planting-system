# ============================================================
# Tree-Planting Field Operations — Monorepo .gitignore
# Covers: Flutter, Nuxt/Node, Dart, Xcode, Gradle, Supabase, .env
# ============================================================

# ─── Environment & Secrets ──────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12

# ─── OS Files ───────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ─── IDE / Editor ───────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# ─── Node.js / Nuxt / pnpm ─────────────────────────────────
node_modules/
.nuxt/
.output/
dist/
.nitro/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ─── Flutter / Dart ─────────────────────────────────────────
# Common
**/doc/api/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.dart_tool/
.metadata

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart
*.config.dart
*.gr.dart

# Flutter-specific
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.dart_tool/
mobile/build/
mobile/.metadata
mobile/.packages

# ─── Android / Gradle ──────────────────────────────────────
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
**/android/**/*.keystore
**/android/**/*.jks
*.apk
*.aab

# ─── iOS / Xcode ───────────────────────────────────────────
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/DerivedData/
**/ios/**/Icon?
**/ios/**/Pods/
**/ios/**/.symlinks/
**/ios/**/profile
**/ios/**/xcuserdata
*.ipa

# ─── Supabase ───────────────────────────────────────────────
supabase/.branches
supabase/.temp/
supabase/.env

# ─── Generated Types (optional — uncomment to track) ───────
# shared/types/database.ts

# ─── Testing / Coverage ────────────────────────────────────
coverage/
.nyc_output/
lcov.info
*.lcov

# ─── Misc ───────────────────────────────────────────────────
*.tgz
*.tar.gz
*.zip
